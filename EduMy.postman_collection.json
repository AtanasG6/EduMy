{
  "info": {
    "name": "EduMy API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5084/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (Student)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ivan\",\n  \"lastName\": \"Ivanov\",\n  \"email\": \"ivan@example.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"Student\"\n}"
            }
          }
        },
        {
          "name": "Register (Lecturer)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Georgi\",\n  \"lastName\": \"Georgiev\",\n  \"email\": \"georgi@example.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"Lecturer\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ivan@example.com\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get my profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/me"
          }
        },
        {
          "name": "Update my profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/users/me",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ivan\",\n  \"lastName\": \"Petrov\"\n}"
            }
          }
        },
        {
          "name": "Change password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/users/me/password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Password123!\",\n  \"newPassword\": \"NewPassword123!\"\n}"
            }
          }
        },
        {
          "name": "[Admin] Get all users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "[Admin] Block user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/1/block"
          }
        },
        {
          "name": "[Admin] Unblock user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/1/unblock"
          }
        },
        {
          "name": "[Admin] Delete user",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/1"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get all categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories"
          }
        },
        {
          "name": "Get category by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories/1"
          }
        },
        {
          "name": "[Admin] Create category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/categories",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Programming\"\n}"
            }
          }
        },
        {
          "name": "[Admin] Update category",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/categories/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Web Development\"\n}"
            }
          }
        },
        {
          "name": "[Admin] Delete category",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/categories/1"
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "Get all courses",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/courses?page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["courses"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "categoryId", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get course by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/courses/1"
          }
        },
        {
          "name": "[Lecturer] Get my courses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/courses/my"
          }
        },
        {
          "name": "[Lecturer] Create course",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/courses",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Introduction to C#\",\n  \"description\": \"Learn C# from scratch.\",\n  \"price\": 29.99,\n  \"categoryId\": 1\n}"
            }
          }
        },
        {
          "name": "[Lecturer] Update course",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/courses/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"C# for Beginners\",\n  \"description\": \"Updated description.\",\n  \"price\": 19.99,\n  \"categoryId\": 1\n}"
            }
          }
        },
        {
          "name": "[Lecturer] Publish course",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/courses/1/publish"
          }
        },
        {
          "name": "[Lecturer] Archive course",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/courses/1/archive"
          }
        },
        {
          "name": "[Lecturer] Delete course",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/courses/1"
          }
        }
      ]
    },
    {
      "name": "Modules",
      "item": [
        {
          "name": "[Lecturer] Create module",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/modules",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseId\": 1,\n  \"title\": \"Getting Started\"\n}"
            }
          }
        },
        {
          "name": "[Lecturer] Update module",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/modules/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Introduction\"\n}"
            }
          }
        },
        {
          "name": "[Lecturer] Delete module",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/modules/1"
          }
        }
      ]
    },
    {
      "name": "Lectures",
      "item": [
        {
          "name": "[Lecturer] Create lecture",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/lectures",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"moduleId\": 1,\n  \"title\": \"Hello World\",\n  \"content\": \"Your first C# program.\",\n  \"videoUrl\": \"https://www.youtube.com/embed/example\"\n}"
            }
          }
        },
        {
          "name": "[Lecturer] Update lecture",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/lectures/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Hello World (Updated)\",\n  \"content\": \"Updated content.\",\n  \"videoUrl\": \"\"\n}"
            }
          }
        },
        {
          "name": "[Lecturer] Delete lecture",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/lectures/1"
          }
        }
      ]
    },
    {
      "name": "Enrollments",
      "item": [
        {
          "name": "Get my enrollments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/enrollments"
          }
        },
        {
          "name": "Get enrollment by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/enrollments/1"
          }
        },
        {
          "name": "Enroll in course",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/enrollments/course/1"
          }
        },
        {
          "name": "Mark lecture complete",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/enrollments/1/lectures/1/complete"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Get reviews for course",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reviews/course/1"
          }
        },
        {
          "name": "Create review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/reviews",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseId\": 1,\n  \"rating\": 5,\n  \"comment\": \"Great course!\"\n}"
            }
          }
        },
        {
          "name": "Delete review",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/reviews/1"
          }
        }
      ]
    },
    {
      "name": "Quizzes",
      "item": [
        {
          "name": "Get quiz for course",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/quizzes/course/1"
          }
        },
        {
          "name": "[Lecturer] Create quiz",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/quizzes",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseId\": 1,\n  \"title\": \"Final Quiz\"\n}"
            }
          }
        },
        {
          "name": "Submit quiz attempt",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/quizzes/1/attempt",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"answers\": [\n    { \"questionId\": 1, \"answerId\": 2 },\n    { \"questionId\": 2, \"answerId\": 5 }\n  ]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Get my payments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/payments"
          }
        },
        {
          "name": "Create payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/payments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseId\": 1\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Diploma",
      "item": [
        {
          "name": "Verify diploma (image upload)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/diploma/verify",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
